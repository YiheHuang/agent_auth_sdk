{
  "name": "agent-identity-sdk",
  "version": "0.1.0",
  "description": "Agent identity resolver and verification SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo:publisher": "npm run build && node dist/demos/publisher-agent.js",
    "demo:verifier": "npm run build && node dist/demos/verifier-agent.js",
    "demo:request": "npm run build && node dist/demos/send-request.js"
  },
  "keywords": [
    "agent",
    "identity",
    "authentication",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.9"
  }
}
